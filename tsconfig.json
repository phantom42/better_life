{
	"compilerOptions": {
	  "target": "ES2020",
	  "lib": ["ES2020", "DOM", "DOM.Iterable"],
	  "module": "ESNext",
	  "moduleResolution": "bundler",
	  "jsx": "react-jsx",
	  "strict": true,
	  "noEmit": true,
	  "skipLibCheck": true,
	  "paths": { "@/*": ["./src/*"] },
	  "types": ["vite/client", "vitest/globals", "@testing-library/jest-dom", "node"]
	},
	"include": ["src"]
}
